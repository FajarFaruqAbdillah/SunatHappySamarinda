---
import { whatsappUrl } from "../data/site";

const consultationUrl = whatsappUrl(
  "Halo Rumah Sunat Happy, saya ingin konsultasi sunat",
);
const isGalleryPage = Astro.url.pathname.startsWith("/galeri");
---

<header class="site-header" id="top">
  <a class="brand" href="/" aria-label="Rumah Sunat Happy Samarinda">
    <span class="brand-mark">SH</span>
    <span>
      <strong>Rumah Sunat Happy</strong>
      <small>Samarinda</small>
    </span>
  </a>
  <button
    class="menu-toggle"
    type="button"
    aria-label="Buka menu"
    aria-expanded="false"
    aria-controls="main-navigation"
  >
    <span></span>
    <span></span>
    <span></span>
  </button>
  <nav class="main-nav" id="main-navigation" aria-label="Navigasi utama">
    <a href="/#layanan">Layanan</a>
    <a href="/#metode">Metode</a>
    <a href="/#proses">Proses</a>
    <a href="/#kontak">Kontak</a>
    <a
      class="nav-gallery"
      href="/galeri/"
      aria-current={isGalleryPage ? "page" : undefined}
    >
      Galeri
    </a>
  </nav>
  <a
    class="header-cta"
    href={consultationUrl}
    target="_blank"
    rel="noopener noreferrer"
  >
    Konsultasi Gratis
  </a>
</header>
