---
import { faqs } from "../data/site";
---

<section class="section faq-section">
  <div class="section-heading">
    <p class="eyebrow">FAQ</p>
    <h2>Pertanyaan yang sering ditanyakan.</h2>
  </div>
  <div class="faq-list">
    {
      faqs.map((faq) => (
        <details>
          <summary>{faq.question}</summary>
          <p>{faq.answer}</p>
        </details>
      ))
    }
  </div>
</section>
