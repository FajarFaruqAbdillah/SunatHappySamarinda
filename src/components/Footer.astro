  href={consultationUrl}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Chat WhatsApp Rumah Sunat Happy"
>
  WA
</a>

<footer class="site-footer">
  <p>&copy; {currentYear} Rumah Sunat Happy Samarinda.</p>
  <a href="#top">Kembali ke atas</a>
</footer>
